# ============================================
# Tennis Matcher - Nginx Configuration
# ============================================

# Rate Limiting Zones
# General API: 5 requests/sec per IP (handles normal browsing)
limit_req_zone $binary_remote_addr zone=api_limit:10m rate=5r/s;
# Login/Auth: 1 request/sec per IP (strict — prevents brute force)
limit_req_zone $binary_remote_addr zone=login_limit:10m rate=1r/s;
# Socket.io: 10 requests/sec per IP (WebSocket handshakes + polling fallback)
limit_req_zone $binary_remote_addr zone=socket_limit:10m rate=10r/s;

server {
    listen 80;
    server_name yourdomain.com www.yourdomain.com; # REPLACE with your actual domain

    # Serve the built React frontend
    # REPLACE with the absolute path to your built React client folder
    root /absolute/path/to/tennis-matcher/client/dist;
    index index.html;

    # React Router — fallback all non-file requests to index.html
    location / {
        try_files $uri /index.html;
    }

    # ---- Login & PIN verification (strictest limit) ----
    # 1 req/sec, burst of 5 — blocks brute force password/PIN guessing
    location /api/login {
        limit_req zone=login_limit burst=5 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    location ~ ^/api/clubs/.+/verify-pin$ {
        limit_req zone=login_limit burst=5 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ---- General API routes (moderate limit) ----
    # 5 req/sec, burst of 10 — normal API usage
    location /api/ {
        limit_req zone=api_limit burst=10 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:4000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }

    # ---- Socket.io (WebSocket + polling) ----
    # 10 req/sec, burst of 20 — allows WebSocket handshake + reconnects
    location /socket.io/ {
        limit_req zone=socket_limit burst=20 nodelay;
        limit_req_status 429;

        proxy_pass http://127.0.0.1:4000;

        # Required for WebSocket upgrade
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    }
}
