# ============================================
# Tennis Matcher - Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Required: Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=your_secret_key_here

# Required (first run only): Password for the root admin account
ROOT_PASSWORD=your_root_password_here

# Optional: Root admin email (default: root@tennis.com)
ROOT_EMAIL=root@tennis.com

# Optional: Allowed frontend origin for CORS (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Optional: Server port (default: 4000)
PORT=4000
